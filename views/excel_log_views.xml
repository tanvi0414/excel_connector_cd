<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_excel_log_list" model="ir.ui.view">
        <field name="name">nl.excel.log.list</field>
        <field name="model">nl.excel.log</field>
        <field name="arch" type="xml">
            <list string="Excel Logs" default_order="create_date desc">
                <field name="create_date" string="Date"/>
                <field name="name"/>
                <field name="profile_id"/>
                <field name="direction"/>
                <field name="state"/>
                <field name="rows_processed"/>
                <field name="rows_failed"/>
                <field name="attachment_id"/>
            </list>
        </field>
    </record>

    <record id="view_excel_log_form" model="ir.ui.view">
        <field name="name">nl.excel.log.form</field>
        <field name="model">nl.excel.log</field>
        <field name="arch" type="xml">
            <form string="Excel Log">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="profile_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="direction"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="rows_processed"/>
                            <field name="rows_failed"/>
                            <field name="attachment_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="message" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_excel_logs" model="ir.actions.act_window">
        <field name="name">Logs</field>
        <field name="res_model">nl.excel.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
