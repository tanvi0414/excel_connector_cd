<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">nl.excel.import.wizard.form</field>
        <field name="model">nl.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Excel File">
                <sheet>
                    <group>
                        <field name="profile_id" readonly="1"/>
                        <field name="file" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="dry_run"/>
                    </group>
                    <group invisible="result_message == False">
                        <field name="result_message" widget="text" readonly="1"/>
                        <field name="error_attachment_id" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_process" type="object" string="Process" class="btn-primary"/>
                    <button name="action_download_error_file" type="object" string="Download Error File" invisible="error_attachment_id == False"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
